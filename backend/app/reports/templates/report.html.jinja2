<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="utf-8">
<style>
  @page { margin: 2cm; }
  body { font-family: 'Helvetica Neue', Arial, sans-serif; color: #1a1a1a; font-size: 11pt; }
  h1, h2 { font-family: 'Courier New', monospace; }
  h1 { color: #0f172a; border-bottom: 3px solid #22d3ee; padding-bottom: 8px; }
  h2 { color: #0f172a; margin-top: 28px; border-bottom: 1px solid #cbd5e1; padding-bottom: 4px; }
  table { width: 100%; border-collapse: collapse; margin: 12px 0; }
  th, td { border: 1px solid #cbd5e1; padding: 6px 10px; text-align: left; font-size: 10pt; }
  th { background: #0f172a; color: white; }
  .meta { color: #475569; font-size: 10pt; margin-bottom: 24px; }
  .finding { margin: 16px 0; padding: 12px; border-left: 4px solid #94a3b8; background: #f8fafc; }
  .finding.critical { border-left-color: #ef4444; }
  .finding.high { border-left-color: #f97316; }
  .finding.medium { border-left-color: #eab308; }
  .finding.low { border-left-color: #3b82f6; }
  .finding.info { border-left-color: #94a3b8; }
  .badge { display: inline-block; font-family: monospace; font-size: 9pt; font-weight: bold; padding: 2px 8px; border-radius: 4px; color: white; }
  .badge.critical { background: #ef4444; }
  .badge.high { background: #f97316; }
  .badge.medium { background: #eab308; }
  .badge.low { background: #3b82f6; }
  .badge.info { background: #94a3b8; }
  .note { font-family: monospace; font-size: 10pt; padding: 6px 0; border-bottom: 1px dashed #e2e8f0; }
</style>
</head>
<body>
  <h1>Reporte de pentesting — {{ engagement.name }}</h1>
  <div class="meta">
    Cliente: {{ engagement.client_name or "N/A" }}<br>
    Periodo: {{ engagement.start_date or "N/A" }} – {{ engagement.end_date or "N/A" }}<br>
    Generado: {{ generated_at.strftime("%Y-%m-%d %H:%M UTC") }}
  </div>

  <h2>Resumen ejecutivo</h2>
  <table>
    <tr><th>Severidad</th><th>Cantidad</th></tr>
    {% for sev in severity_order %}
    <tr><td><span class="badge {{ sev }}">{{ sev|upper }}</span></td><td>{{ severity_counts[sev] }}</td></tr>
    {% endfor %}
  </table>

  <h2>Alcance autorizado</h2>
  {% if scopes %}
  <table>
    <tr><th>Tipo</th><th>Valor</th><th>En alcance</th></tr>
    {% for s in scopes %}
    <tr><td>{{ s.type.value }}</td><td>{{ s.value }}</td><td>{{ "sí" if s.in_scope else "no (excluido)" }}</td></tr>
    {% endfor %}
  </table>
  {% else %}
  <p><em>Sin alcance definido.</em></p>
  {% endif %}

  <h2>Hallazgos ({{ findings|length }})</h2>
  {% for f in findings %}
  <div class="finding {{ f.severity.value }}">
    <span class="badge {{ f.severity.value }}">{{ f.severity.value|upper }}</span>
    <strong>{{ f.title }}</strong> — {{ f.owasp_category }} — estado: {{ f.status.value }}
    {% if f.cvss_score %}<br>CVSS: {{ f.cvss_score }}{% endif %}
    {% if f.mitre_techniques %}<br>MITRE ATT&amp;CK: {{ f.mitre_techniques|join(', ') }}{% endif %}
    <p>{{ f.description or "Sin descripción." }}</p>
  </div>
  {% else %}
  <p><em>No se registraron hallazgos.</em></p>
  {% endfor %}

  <h2>Notas</h2>
  {% for n in notes %}
  <div class="note">{{ n.content }}</div>
  {% else %}
  <p><em>Sin notas.</em></p>
  {% endfor %}
</body>
</html>
