# Copiar a .env y ajustar antes de levantar docker compose

POSTGRES_DB=cyberswiss
POSTGRES_USER=cyberswiss
POSTGRES_PASSWORD=change-me

DATABASE_URL=postgresql+asyncpg://cyberswiss:change-me@postgres/cyberswiss
REDIS_URL=redis://redis:6379/0

JWT_SECRET=change-me-to-a-long-random-string

# true para correr sin pantalla de login (uso local de confianza)
AUTH_DISABLED=false
